  "keyFeatures": [
    "Role-Based Access Control (RBAC) with 5 user types",
    "Product catalog with variants (material, color, stock)",
    "Order management with automatic stock deduction",
    "Inventory tracking with movement audits",
    "Sales reports with JSON data and PDF export",
    "Laravel Sanctum/Passport authentication"
  ],
  "publicApiSurface": [
    "POST /api/login",
    "POST /api/register",
    "GET /api/categorias",
    "GET /api/productos",
    "GET /api/productos/{id}",
    "POST /api/pedidos",
    "GET /api/pedidos",
    "GET /api/inventario",
    "PUT /api/inventario/{id}",
    "GET /api/reportes/ventas",
    "GET /api/reportes/ventas/pdf",
    "POST /api/admin/crear-empleado",
    "GET /api/admin/roles"
  ]
